{
  "manifest_version": 3,
  "name": "Handoff — AI Context Transfer",
  "version": "0.3.0",
  "description": "One-click context transfer between any AI platform — chat, video, image, music, 3D, design, writing.",
  "permissions": ["activeTab", "tabs", "storage", "scripting"],
  "browser_specific_settings": {
    "gecko": {
      "id": "handoff@rofomtl00",
      "strict_min_version": "109.0"
    }
  },
  "host_permissions": [
    "https://*/*",
    "http://localhost/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://*/*"],
      "js": ["extractor.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
