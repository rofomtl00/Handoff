{
  "manifest_version": 3,
  "name": "Handoff — AI Context Transfer",
  "version": "0.3.0",
  "description": "One-click context transfer between any AI platform — chat, video, image, music, 3D, design, writing.",
  "permissions": ["activeTab", "tabs", "storage", "scripting", "nativeMessaging"],
  "browser_specific_settings": {
    "gecko": {
      "id": "handoff@rofomtl00",
      "strict_min_version": "109.0"
    }
  },
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://claude.ai/*",
    "https://gemini.google.com/*",
    "https://aistudio.google.com/*",
    "https://copilot.microsoft.com/*",
    "https://kiro.dev/*",
    "https://grok.com/*",
    "https://x.com/*",
    "https://www.perplexity.ai/*",
    "https://poe.com/*",
    "https://chat.mistral.ai/*",
    "https://chat.deepseek.com/*",
    "https://you.com/*",
    "https://pi.ai/*",
    "https://chat.qwenlm.ai/*",
    "https://huggingface.co/*",
    "https://coral.cohere.com/*",
    "https://chat.reka.ai/*",
    "https://app.fireworks.ai/*",
    "https://app.runwayml.com/*",
    "https://pika.art/*",
    "https://klingai.com/*",
    "https://lumalabs.ai/*",
    "https://sora.com/*",
    "https://midjourney.com/*",
    "https://ideogram.ai/*",
    "https://leonardo.ai/*",
    "https://suno.com/*",
    "https://udio.com/*",
    "https://meshy.ai/*",
    "https://figma.com/*",
    "https://canva.com/*",
    "https://framer.com/*",
    "https://jasper.ai/*",
    "https://notion.so/*",
    "http://localhost/*"
  ],
  "background": {
    "scripts": ["background.js"],
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://aistudio.google.com/*",
        "https://copilot.microsoft.com/*",
        "https://kiro.dev/*",
        "https://grok.com/*",
        "https://x.com/*",
        "https://www.perplexity.ai/*",
        "https://poe.com/*",
        "https://chat.mistral.ai/*",
        "https://chat.deepseek.com/*",
        "https://you.com/*",
        "https://pi.ai/*",
        "https://chat.qwenlm.ai/*",
        "https://huggingface.co/*",
        "https://coral.cohere.com/*",
        "https://chat.reka.ai/*",
        "https://app.fireworks.ai/*",
        "https://app.runwayml.com/*",
        "https://pika.art/*",
        "https://klingai.com/*",
        "https://lumalabs.ai/*",
        "https://sora.com/*",
        "https://midjourney.com/*",
        "https://ideogram.ai/*",
        "https://leonardo.ai/*",
        "https://suno.com/*",
        "https://udio.com/*",
        "https://meshy.ai/*",
        "https://figma.com/*",
        "https://canva.com/*",
        "https://framer.com/*",
        "https://jasper.ai/*",
        "https://notion.so/*"
      ],
      "js": ["extractor.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
